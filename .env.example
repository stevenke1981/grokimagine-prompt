# ── Backend (backend/.env) ───────────────────────────────────────────────────
# OAuth secrets — NEVER expose to frontend
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SECRET_KEY=your-flask-secret

# AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Grok
XAI_API_KEY=

# ── Frontend (frontend/.env.local) ───────────────────────────────────────────
# Public client IDs — safe to expose (no secrets here)
# Required for browser-based PKCE OAuth flow
# If omitted, app falls back to server-side OAuth (/api/auth/google)
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
